pipeline {
    agent { label 'docker-agent' }

    parameters {
        choice(name: 'ENV', choices: ['dev', 'stage', 'prod'], description: 'Куда выполнять deploy')
        booleanParam(name: 'DO_DEPLOY', defaultValue: false, description: 'Выполнять Deploy stage?')
    }

    stages {
        stage('Build') {
            steps {
                dir('second_lesson') {
                    sh 'echo "=== DEBUG ==="'
                    sh 'whoami'
                    sh 'pwd'
                    sh 'ls -la'

                    sh 'python3 --version'
                    sh 'python3 -m pip --version'
                    sh 'python3 -m pip install -r requirements.txt'
                }
            }
        }

        stage('Test') {
            steps {
                dir('second_lesson') {
                    sh 'python3 -m pytest -q tests'
                }
            }
        }

        stage('Deploy') {
            when {
                allOf {
                    branch 'master'
                    expression { params.DO_DEPLOY }
                }
            }
            steps {
                dir('second_lesson') {
                    sh 'mkdir -p deploy'
                    sh 'echo "deployed to ${ENV} at $(date)" > deploy/deploy_${ENV}.txt'
                    sh 'ls -la deploy'
                }
            }
        }
    }

    post {
        success {
            echo 'Pipeline finished SUCCESS'
        }
        failure {
            echo 'Pipeline finished FAILURE'
        }
        always {
            echo "ENV: ${params.ENV}, DO_DEPLOY: ${params.DO_DEPLOY}"
        }
    }
}